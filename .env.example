NODE_ENV=development
PORT=3000

# Required: use a local MongoDB URI for development or your hosted MongoDB URI in deployment.
MONGO_URI=mongodb://127.0.0.1:27017/hostel-helper

# Required: replace with a high-entropy value, for example: openssl rand -hex 32
JWT_SECRET=replace_with_a_random_64_character_secret

# Optional: comma-separated origins allowed to call the API from browsers.
# Same-origin requests are always supported. In production, unset means no cross-origin browser access.
CORS_ORIGINS=http://localhost:3000

# Optional auth/session settings.
JWT_EXPIRES_IN=7d
SESSION_COOKIE_NAME=hh_session

# Optional public contact details shown in the footer. These are public by design.
PUBLIC_CONTACT_ADDRESS=Example Campus Address
PUBLIC_CONTACT_PHONE=+1 555 010 0000
PUBLIC_CONTACT_EMAIL=support@example.edu

# Optional seed credentials. Leave passwords blank to generate random one-time seed passwords.
SEED_ADMIN_USERNAME=demo-admin
SEED_ADMIN_PASSWORD=
SEED_STUDENT_USERNAME=demo-student-001
SEED_STUDENT_PASSWORD=
